{
  "name": "rn-template",
  "main": "src/index.ts",
  "version": "1.0.0",
  "description": "This is a React Native template with Expo and TypeScript.",
  "author": {
    "name": "Eduardo Andrade",
    "email": "eduardo@andradee.com"
  },
  "license": "MIT",
  "engines": {
    "node": ">= 24.17.0"
  },
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx}\"",
    "prepare": "husky",
    "update:deps": "expo install --check",
    "clean-install": "sh ./scripts/clean-and-reinstall.sh"
  },
  "dependencies": {
